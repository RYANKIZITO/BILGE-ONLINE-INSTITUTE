<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/public/css/theme.css" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Courses</title>
</head>
<body class="theme-<%= themePreference || "light" %> catalog-page">
  <div class="page stack-lg">
    <section class="hero-panel catalog-hero">
      <header class="page-header">
        <div>
          <p class="page-eyebrow">Course Catalog</p>
          <h1>Explore premium programmes</h1>
          <p class="page-subtitle">Discover globally relevant courses with clear readiness status, premium presentation, and guided enrollment options.</p>
        </div>
        <div class="button-row">
          <a class="button ghost" href="/my-courses">My Courses</a>
        </div>
      </header>

      <div class="search-bar catalog-search">
        <label class="sr-only" for="courseSearch">Search courses</label>
        <input id="courseSearch" type="search" placeholder="Search by title..." />

        <label class="sr-only" for="categoryFilter">Filter by category</label>
        <select id="categoryFilter">
          <option value="__all__">All Categories</option>
          <% Object.entries(groupedCourses || {}).forEach(([category]) => { %>
            <option value="<%= category %>"><%= category %></option>
          <% }) %>
        </select>

        <button type="button" id="sortToggle" data-order="asc">Sort A-Z</button>
      </div>
    </section>

    <% if (flash && flash.message) { %>
      <div class="flash flash-<%= flash.type || "info" %>"><%= flash.message %></div>
    <% } %>

    <% const categories = Object.entries(groupedCourses || {}); %>
    <% const truncate = (text, length = 160) => {
      const value = String(text || "");
      return value.length > length ? `${value.slice(0, length - 3)}...` : value;
    }; %>
    <% const toId = (text) =>
      String(text || "")
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, ""); %>

    <% if (categories.length === 0) { %>
      <div class="empty-state">No courses are available right now.</div>
    <% } else { %>
      <nav class="nav-links surface catalog-nav">
        <% categories.forEach(([category, courses]) => { %>
          <a href="#category-<%= toId(category) %>" data-category-id="category-<%= toId(category) %>">
            <%= category %> (<%= courses.length %>)
          </a>
        <% }) %>
      </nav>

      <% categories.forEach(([category, courses]) => { %>
        <section class="stack-md category-block catalog-category" data-category="<%= category %>" id="category-<%= toId(category) %>">
          <header class="page-header catalog-category__header" style="margin-bottom: 0;">
            <div>
              <p class="page-eyebrow">Category</p>
              <h2 class="page-title" style="font-size: clamp(1.45rem, 3vw, 2rem);"><span class="category-name"><%= category %></span></h2>
            </div>
            <div class="badge info category-count" data-total="<%= courses.length %>"><%= courses.length %> course(s)</div>
          </header>

          <div class="course-grid">
            <% courses.forEach(course => { %>
              <% const isEnrolled = enrolledCourseIds && enrolledCourseIds.includes(course.id); %>
              <% const pendingSwitchTopUp = pendingSwitchTopUpByCourseId && pendingSwitchTopUpByCourseId[course.id]; %>
              <article
                class="card course-card course-item catalog-course-card"
                data-title="<%= course.title.toLowerCase() %>"
                data-status="<%= course.status %>"
                data-category="<%= category %>"
              >
                <header class="catalog-course-card__header">
                  <div class="button-row catalog-course-card__status">
                    <span class="badge <%= course.status === "READY" ? "success" : "warning" %>">
                      <%= course.status %>
                    </span>
                    <% if (isEnrolled) { %>
                      <span class="badge info">Enrolled</span>
                    <% } %>
                  </div>
                  <h3><%= course.title %></h3>
                </header>

                <p class="catalog-course-card__description"><%= truncate(course.description) %></p>

                <% if (pendingSwitchTopUp) { %>
                  <p class="muted catalog-course-card__notice">
                    Approved switch from <strong><%= pendingSwitchTopUp.course?.title || "your previous course" %></strong>.
                    Top-up due: <strong><%= pendingSwitchTopUp.switchBalanceAmount %> <%= pendingSwitchTopUp.switchPricingCurrency %></strong>
                  </p>
                <% } %>

                <div class="course-actions catalog-course-actions">
                  <% if (isEnrolled) { %>
                    <a class="button primary" href="/my-courses">Go to My Courses</a>
                  <% } else if (pendingSwitchTopUp) { %>
                    <a class="button primary" href="/payments/switch-top-up/<%= pendingSwitchTopUp.id %>">Complete Switch Top-Up</a>
                    <a class="button ghost" href="/my-courses">Review Switch</a>
                  <% } else if (course.status === "COMING_SOON") { %>
                    <span class="button disabled">Coming Soon</span>
                  <% } else if (isSampleStudent) { %>
                    <form method="POST" action="/courses/<%= course.id %>/enroll">
                      <button class="primary" type="submit">Enroll (Sample)</button>
                    </form>
                  <% } else { %>
                    <form method="POST" action="/payments/start">
                      <input type="hidden" name="courseId" value="<%= course.id %>" />
                      <input type="hidden" name="provider" value="stripe" />
                      <button class="primary" type="submit">Pay with Card</button>
                    </form>
                    <form method="POST" action="/payments/start">
                      <input type="hidden" name="courseId" value="<%= course.id %>" />
                      <input type="hidden" name="provider" value="pesapal" />
                      <button type="submit">Pay with Mobile Money</button>
                    </form>
                    <form method="POST" action="/payments/start">
                      <input type="hidden" name="courseId" value="<%= course.id %>" />
                      <input type="hidden" name="provider" value="paypal" />
                      <button class="ghost" type="submit">Pay with PayPal</button>
                    </form>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </section>
      <% }) %>
    <% } %>
  </div>

  <script>
    const searchInput = document.getElementById("courseSearch");
    const categoryFilter = document.getElementById("categoryFilter");
    const sortToggle = document.getElementById("sortToggle");
    const categoryBlocks = Array.from(document.querySelectorAll(".category-block"));
    const navLinks = Array.from(document.querySelectorAll("[data-category-id]"));

    const applyFilterAndSort = () => {
      const query = searchInput.value.trim().toLowerCase();
      const selectedCategory = categoryFilter.value;
      const order = sortToggle.dataset.order || "asc";

      categoryBlocks.forEach((block) => {
        const items = Array.from(block.querySelectorAll(".course-item"));
        let visibleCount = 0;

        items.forEach((item) => {
          const title = item.dataset.title || "";
          const matchesSearch = !query || title.includes(query);
          const matchesCategory =
            selectedCategory === "__all__" || item.dataset.category === selectedCategory;
          const matches = matchesSearch && matchesCategory;
          item.style.display = matches ? "" : "none";
          if (matches) visibleCount += 1;
        });

        block.style.display = visibleCount > 0 ? "" : "none";

        const countEl = block.querySelector(".category-count");
        if (countEl) {
          countEl.textContent = `${visibleCount} course(s)`;
        }

        const sorted = items
          .slice()
          .sort((a, b) => {
            const aTitle = a.dataset.title || "";
            const bTitle = b.dataset.title || "";
            return order === "asc"
              ? aTitle.localeCompare(bTitle)
              : bTitle.localeCompare(aTitle);
          });

        const list = block.querySelector(".course-grid");
        sorted.forEach((item) => list.appendChild(item));
      });

      navLinks.forEach((link) => {
        const targetId = link.dataset.categoryId;
        const target = document.getElementById(targetId);
        link.style.display = target && target.style.display !== "none" ? "" : "none";
      });
    };

    searchInput.addEventListener("input", applyFilterAndSort);
    categoryFilter.addEventListener("change", applyFilterAndSort);
    sortToggle.addEventListener("click", () => {
      const nextOrder = sortToggle.dataset.order === "asc" ? "desc" : "asc";
      sortToggle.dataset.order = nextOrder;
      sortToggle.textContent = nextOrder === "asc" ? "Sort A-Z" : "Sort Z-A";
      applyFilterAndSort();
    });

    applyFilterAndSort();
  </script>
</body>
</html>
