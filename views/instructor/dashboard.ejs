<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/public/css/theme.css" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Instructor Dashboard</title>
  <link rel="stylesheet" href="/public/css/dashboards.css" />
</head>
<body class="theme-<%= themePreference || "light" %>">
  <div class="page dashboard-shell">
    <section class="hero-panel dashboard-hero">
      <header class="page-header">
        <div>
          <p class="page-eyebrow">Teaching Workspace</p>
          <h1>Welcome, <%= user?.name || "Instructor" %></h1>
          <p class="page-subtitle">Manage your assigned courses, publishing flow, and teaching actions from one refined workspace.</p>
        </div>
        <div class="dashboard-header-actions">
          <button class="dashboard-theme-toggle" type="button" data-theme-toggle aria-label="Switch theme">
            <span class="dashboard-theme-toggle__label">Theme</span>
            <span class="dashboard-theme-toggle__track" aria-hidden="true">
              <span class="dashboard-theme-toggle__thumb"></span>
            </span>
            <span class="dashboard-theme-toggle__current" data-theme-current><%= themePreference === "light" ? "Light" : "Dark" %></span>
          </button>
          <div class="bilge-language-dock bilge-language-dock--inline" data-bilge-language-dock>
            <label class="bilge-language-control" for="bilge-global-language">
              <span>Language</span>
              <select id="bilge-global-language" data-language-select aria-label="Select application language"></select>
            </label>
          </div>
          <nav class="nav-links">
            <a href="/dashboard">My Dashboard</a>
            <% if (user?.profileCompleted) { %>
              <a href="/settings">Settings</a>
            <% } %>
            <form class="nav-logout-form" method="POST" action="/logout">
              <button type="submit" class="button">Log Out</button>
            </form>
          </nav>
        </div>
      </header>
    </section>
    <div id="google_translate_element" class="google-translate-anchor" aria-hidden="true"></div>

    <% if (flash && flash.message) { %>
      <div class="flash flash-<%= flash.type || "info" %>"><%= flash.message %></div>
    <% } %>

    <section class="dashboard-kpis">
      <article class="card dashboard-kpi">
        <h3>Assigned Courses</h3>
        <% if (!assignmentFeatureAvailable) { %>
          <p class="muted">Assignment tooling is being prepared.</p>
        <% } else { %>
          <div class="metric-label">Current teaching load</div>
          <p class="big"><%= myCourses.length %></p>
          <div class="split">
            <span>Published: <%= myCourses.filter((course) => course.published).length %></span>
            <span>Draft or pending: <%= myCourses.filter((course) => !course.published).length %></span>
          </div>
        <% } %>
      </article>

      <article class="card dashboard-kpi">
        <h3>ActiveState</h3>
        <% const activeStateTone = engagementSnapshot?.activeState === "Active" ? "success" : engagementSnapshot?.activeState === "At-Risk" ? "warning" : "info"; %>
        <div class="metric-label">Current monthly engagement state</div>
        <p class="big"><%= engagementSnapshot?.activeState || "Inactive" %></p>
        <div class="split">
          <span>Attendance: <%= Number(engagementSnapshot?.attendanceRate || 0).toFixed(1) %>%</span>
          <span>Score: <%= Number(engagementSnapshot?.performanceScore || 0).toFixed(1) %></span>
        </div>
        <div class="split">
          <span>Response: <%= engagementSnapshot && engagementSnapshot.averageResponseHours !== null ? `${Number(engagementSnapshot.averageResponseHours).toFixed(1)} hrs` : "No answered questions" %></span>
          <span>Overdue Q&A: <%= engagementSnapshot?.pendingQuestionsOverSla || 0 %></span>
        </div>
        <div style="margin-top: 0.75rem;">
          <span class="badge <%= activeStateTone %>"><%= engagementSnapshot?.activeState || "Inactive" %></span>
        </div>
      </article>

      <article class="card dashboard-kpi">
        <h3>Quick Actions</h3>
        <% const quickCourse = myCourses && myCourses.length === 1 ? myCourses[0] : null; %>
        <% const quickLessonHref = quickCourse ? `/instructor/courses/${quickCourse.id}/lessons/new` : "/instructor/courses"; %>
        <div class="stack-sm">
          <a class="button primary" href="<%= quickLessonHref %>">Upload Content</a>
          <a class="button ghost" href="/instructor/assessments">Create Quiz</a>
          <a class="button ghost" href="<%= quickLessonHref %>">Add Lesson</a>
        </div>
      </article>
    </section>

    <section class="card dashboard-panel">
      <div class="dashboard-panel-header">
        <div>
          <p class="page-eyebrow">Live Session Tomorrow</p>
          <h2>Next-Day Reminder</h2>
          <p class="muted">Times below are shown in your local time so you can prepare before the class starts.</p>
        </div>
      </div>

      <div data-live-tomorrow-section>
        <% if (!nextDayLiveSessionAlerts || nextDayLiveSessionAlerts.length === 0) { %>
          <div class="empty-state" data-live-tomorrow-empty>No live sessions are currently lined up for tomorrow.</div>
        <% } else { %>
          <div class="stack-md" data-live-tomorrow-list>
            <% nextDayLiveSessionAlerts.forEach((alert) => { %>
              <article class="list-card stack-sm" data-live-tomorrow-item data-session-start-time="<%= new Date(alert.startTime).toISOString() %>">
                <div class="split">
                  <div>
                    <strong><%= alert.courseTitle %></strong>
                    <div class="muted"><%= alert.sessionTypeLabel %> with <%= alert.instructor %></div>
                  </div>
                  <span class="badge info">Tomorrow</span>
                </div>
                <div class="muted">
                  Starts
                  <time data-local-datetime="<%= new Date(alert.startTime).toISOString() %>" data-local-format="session"><%= new Date(alert.startTime).toLocaleString() %></time>
                </div>
                <% if (alert.meetingUrl) { %>
                  <div class="button-row">
                    <% const nextDayJoinOpen = new Date(alert.startTime).getTime() <= Date.now(); %>
                    <a
                      class="button ghost <%= nextDayJoinOpen ? "" : "is-disabled" %>"
                      <% if (nextDayJoinOpen) { %>href="<%= alert.meetingUrl %>"<% } %>
                      target="_blank"
                      rel="noopener noreferrer"
                      data-live-session-join
                      data-live-session-url="<%= alert.meetingUrl %>"
                      data-session-start-time="<%= new Date(alert.startTime).toISOString() %>"
                    >Open Google Meet</a>
                  </div>
                <% } %>
              </article>
            <% }) %>
          </div>
          <div class="empty-state" data-live-tomorrow-empty hidden>No live sessions are currently lined up for tomorrow in your local time.</div>
        <% } %>
      </div>
    </section>

    <section class="card dashboard-panel">
      <div class="dashboard-panel-header">
        <div>
          <p class="page-eyebrow">Live Session Soon</p>
          <h2>Upcoming Session Alerts</h2>
          <p class="muted">Starts-at times below are shown in your local time.</p>
        </div>
      </div>

      <% if (!upcomingLiveSessionAlerts || upcomingLiveSessionAlerts.length === 0) { %>
        <div class="empty-state">No live sessions are starting within the next 15 to 30 minutes.</div>
      <% } else { %>
        <div class="stack-md">
          <% upcomingLiveSessionAlerts.forEach((alert) => { %>
            <article class="list-card stack-sm">
              <div class="split">
                <div>
                  <strong><%= alert.courseTitle %></strong>
                  <div class="muted"><%= alert.sessionTypeLabel %> with <%= alert.instructor %></div>
                </div>
                <span class="badge warning"><%= alert.minutesRemaining %> min</span>
              </div>
              <div class="muted">
                Starts at
                <time data-local-datetime="<%= new Date(alert.startTime).toISOString() %>" data-local-format="session"><%= new Date(alert.startTime).toLocaleString() %></time>
              </div>
              <% if (alert.meetingUrl) { %>
                <div class="button-row">
                  <% const upcomingJoinOpen = new Date(alert.startTime).getTime() <= Date.now(); %>
                  <a
                    class="button primary <%= upcomingJoinOpen ? "" : "is-disabled" %>"
                    <% if (upcomingJoinOpen) { %>href="<%= alert.meetingUrl %>"<% } %>
                    target="_blank"
                    rel="noopener noreferrer"
                    data-live-session-join
                    data-live-session-url="<%= alert.meetingUrl %>"
                    data-session-start-time="<%= new Date(alert.startTime).toISOString() %>"
                  >Join Google Meet</a>
                </div>
              <% } %>
            </article>
          <% }) %>
        </div>
      <% } %>
    </section>

    <section class="card dashboard-panel">
      <div class="dashboard-panel-header">
        <div>
          <p class="page-eyebrow">Teaching Portfolio</p>
          <h2>My Courses</h2>
        </div>
      </div>

      <% if (!assignmentFeatureAvailable) { %>
        <div class="empty-state">Course assignment features are coming soon.</div>
      <% } else if (myCourses.length === 0) { %>
        <div class="empty-state">No courses are assigned yet.</div>
      <% } else { %>
        <div class="table-wrap dashboard-table">
          <table class="table">
            <thead>
              <tr>
                <th>Course</th>
                <th>Status</th>
                <th>Created</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% myCourses.forEach(course => { %>
                <tr>
                  <td><strong><%= course.title %></strong></td>
                  <td>
                    <span class="badge <%= course.published ? "success" : "warning" %>">
                      <%= course.published ? "Published" : course.status %>
                    </span>
                  </td>
                  <td><%= new Date(course.createdAt).toLocaleDateString() %></td>
                  <td>
                    <div class="actions">
                      <a class="button ghost" href="/instructor/courses/<%= course.id %>/manage">Manage</a>
                      <% if (course.published) { %>
                        <form class="inline-form" method="POST" action="/instructor/courses/<%= course.id %>/unpublish">
                          <button type="submit">Unpublish</button>
                        </form>
                      <% } else { %>
                        <form class="inline-form" method="POST" action="/instructor/courses/<%= course.id %>/publish">
                          <button class="primary" type="submit">Publish</button>
                        </form>
                      <% } %>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

    <%- include("../partials/lms-feedback-panel", {
      user,
      dashboardLabel: "Instructor Dashboard",
      pagePath: "/instructor/dashboard",
    }) %>
  </div>
</body>
</html>
