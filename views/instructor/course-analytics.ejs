<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/public/css/theme.css" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= course.title %> Analytics</title>
  <link rel="stylesheet" href="/public/css/dashboards.css" />

  <style>
    .catalog-link {
      text-decoration: none;
      padding: 6px 10px;
      border: 1px solid #ddd;
      border-radius: 6px;
      font-size: 14px;
      background: #f9f9f9;
      display: inline-block;
      margin-right: 8px;
      margin-bottom: 12px;
    }

    .analytics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 14px;
      margin: 20px 0;
    }

    .analytics-card {
      border: 1px solid #e5e5e5;
      border-radius: 8px;
      padding: 14px;
      background: #fff;
    }

    .analytics-card strong {
      display: block;
      margin-bottom: 6px;
    }

    .analytics-section {
      margin-top: 24px;
    }

    .analytics-section h2 {
      margin-bottom: 10px;
    }

    .insight-list {
      display: grid;
      gap: 12px;
      margin-top: 12px;
    }

    .insight-card {
      border: 1px solid #e5e5e5;
      border-left-width: 5px;
      border-radius: 8px;
      padding: 12px;
      background: #fff;
    }

    .insight-card.warning {
      border-left-color: #f59e0b;
      background: #fffaf0;
    }

    .insight-card.success {
      border-left-color: #10b981;
      background: #f0fdf4;
    }

    .insight-card.info {
      border-left-color: #3b82f6;
      background: #eff6ff;
    }

    .insight-card h3 {
      margin: 0 0 6px 0;
      font-size: 16px;
    }

    .insight-card p {
      margin: 6px 0;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
    }

    th,
    td {
      border: 1px solid #e5e5e5;
      padding: 8px;
      text-align: left;
      vertical-align: top;
    }

    .bar-row {
      margin-bottom: 10px;
    }

    .bar-label {
      margin-bottom: 4px;
      font-size: 14px;
    }

    .bar-track {
      width: 100%;
      background: #f1f1f1;
      border-radius: 999px;
      height: 12px;
      overflow: hidden;
    }

    .bar-fill {
      height: 12px;
      background: #4f46e5;
    }
  </style>
</head>

<body class="theme-<%= themePreference || "light" %>">
  <div class="page">
      <header class="page-header">
        <div>
        <h1><%= course.title %> Analytics</h1>
        <p class="muted">Advanced instructor course analytics, insights, and diagnostics</p>
      </div>

      <nav class="nav-links">
        <a href="/instructor/courses/<%= course.id %>/manage">Back to Course</a>
      </nav>
    </header>

    <% if (flash && flash.message) { %>
      <div class="flash flash-<%= flash.type || "info" %>"><%= flash.message %></div>
    <% } %>

    <div class="analytics-grid">
      <div class="analytics-card">
        <strong>Total Students</strong>
        <%= analytics.totalStudents %>
      </div>

      <div class="analytics-card">
        <strong>Completed Students</strong>
        <%= analytics.completedStudents %>
      </div>

      <div class="analytics-card">
        <strong>Completion Rate</strong>
        <%= analytics.completionRate.toFixed(2) %>%
      </div>

      <div class="analytics-card">
        <strong>Average Course Score</strong>
        <%= analytics.averageCourseScore.toFixed(2) %>%
      </div>
    </div>

    <div class="analytics-section">
      <h2>Instructor Insights</h2>

      <% if (!analytics.insights || !analytics.insights.length) { %>
        <p>No insight data yet.</p>
      <% } else { %>
        <div class="insight-list">
          <% analytics.insights.forEach((insight) => { %>
            <div class="insight-card <%= insight.level %>">
              <h3><%= insight.title %></h3>
              <p><%= insight.message %></p>
              <p><strong>Recommended action:</strong> <%= insight.action %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Course Diagnostics</h2>

      <% if (!analytics.diagnostics || !analytics.diagnostics.length) { %>
        <p>No diagnostic data yet.</p>
      <% } else { %>
        <div class="insight-list">
          <% analytics.diagnostics.forEach((diagnostic) => { %>
            <div class="insight-card <%= diagnostic.level %>">
              <h3><%= diagnostic.signal %></h3>
              <p><%= diagnostic.finding %></p>
              <p><strong>Recommended action:</strong> <%= diagnostic.recommendation %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Question Diagnostics</h2>

      <% if (!analytics.questionDiagnostics || !analytics.questionDiagnostics.length) { %>
        <p>No question diagnostic data yet.</p>
      <% } else { %>
        <div class="insight-list">
          <% analytics.questionDiagnostics.forEach((diagnostic) => { %>
            <div class="insight-card <%= diagnostic.level %>">
              <h3><%= diagnostic.signal %></h3>
              <p><%= diagnostic.finding %></p>
              <p><strong>Recommended action:</strong> <%= diagnostic.recommendation %></p>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Score Distribution</h2>

      <% analytics.scoreDistribution.forEach((bucket) => { %>
        <div class="bar-row">
          <div class="bar-label"><%= bucket.label %> — <%= bucket.count %> student(s)</div>
          <div class="bar-track">
            <% const percent = analytics.totalStudents > 0 ? (bucket.count / analytics.totalStudents) * 100 : 0; %>
            <div
              class="bar-fill"
              style="width:<%= percent %>%"
            ></div>
          </div>
        </div>
      <% }) %>
    </div>

    <div class="analytics-section">
      <h2>Hardest Assessments</h2>

      <% if (!analytics.hardestAssessments.length) { %>
        <p>No assessment data yet.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Assessment</th>
              <th>Type</th>
              <th>Submissions</th>
              <th>Average Score</th>
              <th>Average %</th>
            </tr>
          </thead>
          <tbody>
            <% analytics.hardestAssessments.forEach((assessment) => { %>
              <tr>
                <td><%= assessment.title %></td>
                <td><%= assessment.type %></td>
                <td><%= assessment.submissionCount %></td>
                <td><%= assessment.averageScore.toFixed(2) %> / <%= assessment.maxScore %></td>
                <td><%= assessment.averagePercent.toFixed(2) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Strongest Students</h2>

      <% if (!analytics.strongestStudents.length) { %>
        <p>No student grade data yet.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Student</th>
              <th>Email</th>
              <th>Final Course Mark</th>
            </tr>
          </thead>
          <tbody>
            <% analytics.strongestStudents.forEach((row) => { %>
              <tr>
                <td><%= row.student.name %></td>
                <td><%= row.student.email %></td>
                <td><%= row.summary.finalCourseMark.toFixed(2) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Weakest Students</h2>

      <% if (!analytics.weakestStudents.length) { %>
        <p>No student grade data yet.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Student</th>
              <th>Email</th>
              <th>Final Course Mark</th>
            </tr>
          </thead>
          <tbody>
            <% analytics.weakestStudents.forEach((row) => { %>
              <tr>
                <td><%= row.student.name %></td>
                <td><%= row.student.email %></td>
                <td><%= row.summary.finalCourseMark.toFixed(2) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Lesson Drop-off Analysis</h2>

      <% if (!analytics.lessonDropoff.length) { %>
        <p>No lesson progress data yet.</p>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Lesson</th>
              <th>Completed By</th>
              <th>Completion %</th>
            </tr>
          </thead>
          <tbody>
            <% analytics.lessonDropoff.forEach((lesson) => { %>
              <tr>
                <td>Lesson <%= lesson.position %>: <%= lesson.title %></td>
                <td><%= lesson.completedCount %> student(s)</td>
                <td><%= lesson.completionPercent.toFixed(2) %>%</td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="analytics-section">
      <h2>Assessment Question Diagnostics</h2>

      <% if (!analytics.assessmentQuestionStats || !analytics.assessmentQuestionStats.length) { %>
        <p>No question analytics yet.</p>
      <% } else { %>
        <% analytics.assessmentQuestionStats.forEach((assessment) => { %>
          <div class="insight-card info" style="margin-bottom: 16px;">
            <h3><%= assessment.title %> (<%= assessment.type %>)</h3>

            <% if (!assessment.questionStats || !assessment.questionStats.length) { %>
              <p>No question stats yet.</p>
            <% } else { %>
              <table>
                <thead>
                  <tr>
                    <th>Question</th>
                    <th>Type</th>
                    <th>Responses</th>
                    <th>Success %</th>
                  </tr>
                </thead>
                <tbody>
                  <% assessment.questionStats.forEach((question) => { %>
                    <tr>
                      <td><%= question.prompt %></td>
                      <td><%= question.type %></td>
                      <td><%= question.totalResponses %></td>
                      <td><%= question.successPercent.toFixed(2) %>%</td>
                    </tr>

                    <% if (question.type === "SHORT_TEXT" && question.keywordStats && question.keywordStats.length) { %>
                      <tr>
                        <td colspan="4">
                          <strong>Keyword matches</strong>
                          <ul>
                            <% question.keywordStats.forEach((keywordStat) => { %>
                              <li>
                                <%= keywordStat.keyword %> —
                                <%= keywordStat.matchedCount %> match(es)
                                (<%= keywordStat.matchPercent.toFixed(2) %>%)
                              </li>
                            <% }) %>
                          </ul>
                        </td>
                      </tr>
                    <% } %>

                    <% if (question.type === "MULTIPLE_CHOICE" && question.optionStats && question.optionStats.length) { %>
                      <tr>
                        <td colspan="4">
                          <strong>Option selection pattern</strong>
                          <ul>
                            <% question.optionStats.forEach((optionStat) => { %>
                              <li>
                                <%= optionStat.option %>
                                <% if (optionStat.isCorrectOption) { %>
                                  <strong>(Correct)</strong>
                                <% } %>
                                — <%= optionStat.selections %> selection(s)
                              </li>
                            <% }) %>
                          </ul>
                        </td>
                      </tr>
                    <% } %>
                  <% }) %>
                </tbody>
              </table>
            <% } %>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>
</body>
</html>

