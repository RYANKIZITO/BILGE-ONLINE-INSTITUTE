<!DOCTYPE html>
<html>
<head>
  <link rel="stylesheet" href="/public/css/theme.css" />
  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Certificate Verification</title>
    <style>
      body {
        margin: 0;
        padding: 24px;
        background: #f5f7fb;
        font-family: Arial, sans-serif;
        color: #1f2937;
      }

      .wrapper {
        max-width: 1000px;
        margin: 0 auto;
      }

      .card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 24px;
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.06);
        margin-bottom: 20px;
      }

      .title {
        font-size: 32px;
        margin: 0 0 8px;
      }

      .ok {
        color: #166534;
        font-weight: 700;
      }

      .bad {
        color: #991b1b;
        font-weight: 700;
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(260px, 1fr));
        gap: 16px 24px;
        margin-top: 20px;
      }

      .label {
        font-size: 12px;
        text-transform: uppercase;
        color: #6b7280;
        margin-bottom: 4px;
      }

      .value {
        font-size: 18px;
        font-weight: 600;
      }

      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
      }

      th,
      td {
        border-bottom: 1px solid #e5e7eb;
        text-align: left;
        padding: 12px 8px;
      }

      th {
        font-size: 13px;
        text-transform: uppercase;
        color: #6b7280;
      }

      td {
        font-size: 15px;
      }

      .section-title {
        font-size: 22px;
        margin: 0 0 10px;
      }

      @media (max-width: 700px) {
        .grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body class="theme-<%= themePreference || "light" %>">
    <div class="wrapper">
      <% if (!valid) { %>
        <div class="card">
          <h1 class="title bad">Certificate Not Found</h1>
          <p>The verification code is invalid or the certificate does not exist.</p>
        </div>
      <% } else { %>
        <div class="card">
          <h1 class="title ok">Certificate Verified</h1>
          <p>This certificate is valid and was issued by Bilge Online Institute.</p>

          <div class="grid">
            <div>
              <div class="label">Student Name</div>
              <div class="value"><%= cert.user.name %></div>
            </div>

            <div>
              <div class="label">Course</div>
              <div class="value"><%= cert.course.title %></div>
            </div>

            <div>
              <div class="label">Certificate Number</div>
              <div class="value" style="overflow-wrap: anywhere; word-break: break-word; line-height: 1.35;"><%= cert.certificateNumber || "Pending" %></div>
            </div>

            <div>
              <div class="label">Verification Code</div>
              <div class="value"><%= cert.verificationCode %></div>
            </div>

            <div>
              <div class="label">Issued On</div>
              <div class="value">
                <%= new Date(cert.issuedAt).toLocaleDateString("en-GB", {
                  day: "2-digit",
                  month: "long",
                  year: "numeric",
                }) %>
              </div>
            </div>

            <div>
              <div class="label">Instructor</div>
              <div class="value"><%= cert.course.instructor?.name || "Bilge Online Institute" %></div>
            </div>

            <div>
              <div class="label">Date of Birth</div>
              <div class="value">
                <%= cert.user.dateOfBirth
                  ? new Date(cert.user.dateOfBirth).toLocaleDateString("en-GB", {
                      day: "2-digit",
                      month: "long",
                      year: "numeric",
                    })
                  : "Not provided" %>
              </div>
            </div>

            <div>
              <div class="label">Parent Names</div>
              <div class="value"><%= cert.user.parentNames || "Not provided" %></div>
            </div>
          </div>
        </div>

        <div class="card">
          <h2 class="section-title">Academic Transcript</h2>

          <% if (!transcriptRows || transcriptRows.length === 0) { %>
            <p>No transcript records found.</p>
          <% } else { %>
            <%
            function getGrade(score) {
              if (score >= 80) return { grade: "A", gpa: 4.0 };
              if (score >= 75) return { grade: "B+", gpa: 3.5 };
              if (score >= 70) return { grade: "B", gpa: 3.0 };
              if (score >= 65) return { grade: "C+", gpa: 2.5 };
              if (score >= 60) return { grade: "C", gpa: 2.0 };
              if (score >= 55) return { grade: "D+", gpa: 1.5 };
              if (score >= 50) return { grade: "D", gpa: 1.0 };
              return { grade: "F", gpa: 0.0 };
            }
            const finalResult = getGrade(finalCourseMark || 0);
            %>
            <div style="margin: 8px 0 18px;">
              <h3 class="section-title" style="font-size:18px; margin-bottom:8px;">
                Transcript Summary
              </h3>
              <div class="grid" style="margin-top: 8px;">
                <div>
                  <div class="label">Final Weighted Mark</div>
                  <div class="value"><%= finalCourseMark %>%</div>
                </div>
                <div>
                  <div class="label">CGPA</div>
                  <div class="value"><%= finalResult.gpa.toFixed(1) %></div>
                </div>
              </div>
            </div>
            <table>
              <thead>
                <tr>
                  <th>Assessment</th>
                  <th>Type</th>
                  <th>Grade</th>
                  <th>GPA</th>
                  <th>Attempt</th>
                  <th>Submitted</th>
                </tr>
              </thead>
              <tbody>
                <% transcriptRows.forEach((row) => { %>
                  <% const result = getGrade(row.score || 0); %>
                  <tr>
                    <td><%= row.title %></td>
                    <td><%= row.type %></td>
                    <td><%= result.grade %></td>
                    <td><%= result.gpa.toFixed(1) %></td>
                    <td><%= row.attempt ?? "-" %></td>
                    <td>
                      <%= row.submittedAt
                        ? new Date(row.submittedAt).toLocaleDateString("en-GB", {
                            day: "2-digit",
                            month: "short",
                            year: "numeric",
                          })
                        : "-" %>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          <% } %>
        </div>
      <% } %>
    </div>
  </body>
</html>


