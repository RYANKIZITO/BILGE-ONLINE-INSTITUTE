<!DOCTYPE html>
<html lang="en">
<head>
  <link rel="stylesheet" href="/public/css/theme.css" />
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Register</title>
</head>
<body class="theme-<%= themePreference || "light" %>">
  <div class="auth-shell">
    <section class="auth-card">
      <aside class="auth-aside">
        <%- include("partials/brand-panel", {
          mark: "Premium Enrollment",
          kicker: "Admissions and onboarding",
          title: "Start with a polished account setup designed for premium academic delivery.",
          description: "Create your Bilge account to enter a structured institute environment for enrollment, learning progress, transcripts, payments, and verified certification.",
          highlights: [
            {
              title: "Professional onboarding",
              description: "Set up your account once and continue into a complete academic profile with guided next steps.",
            },
            {
              title: "Visible progression",
              description: "From registration to coursework and final certification, each stage stays clear and organized.",
            },
            {
              title: "Institution-ready records",
              description: "Your account powers student identity, assessments, transcripts, and formal completion workflows.",
            },
          ],
          metrics: [
            { value: "Access", label: "Secure sign-in and onboarding" },
            { value: "Progress", label: "Assessment and study continuity" },
            { value: "Completion", label: "Certificate-ready records" },
          ],
          supportText: "Create your account once, complete your profile, and continue into the full Bilge learning system with confidence.",
        }) %>
      </aside>

      <main class="auth-main">
        <div class="stack-md">
          <header>
            <p class="page-eyebrow">Create Account</p>
            <h2 class="page-title">Register for Bilge</h2>
            <p class="page-subtitle">Set up your account and continue into your academic profile.</p>
          </header>

          <% if (error) { %>
            <div class="flash flash-error"><%= error %></div>
          <% } %>

          <div class="auth-socials" aria-label="Social sign up options">
            <a
              class="button social-button"
              href="<%= socialAuth?.google?.enabled ? '/auth/google?mode=register' : '#' %>"
              <%= socialAuth?.google?.enabled ? '' : 'aria-disabled="true" tabindex="-1"' %>
            >
              Sign up with Google
            </a>
            <a
              class="button social-button"
              href="<%= socialAuth?.apple?.enabled ? '/auth/apple?mode=register' : '#' %>"
              <%= socialAuth?.apple?.enabled ? '' : 'aria-disabled="true" tabindex="-1"' %>
            >
              Sign up with Apple ID
            </a>
          </div>

          <% if (!socialAuth?.google?.enabled || !socialAuth?.apple?.enabled) { %>
            <p class="muted auth-meta">
              Social sign-up is wired into this page. Add the matching provider environment variables to enable each button.
            </p>
          <% } %>

          <div class="auth-divider" aria-hidden="true"><span>or register with email</span></div>

          <form class="auth-form" method="POST" action="/register" enctype="multipart/form-data">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" type="text" autocomplete="name" required />
            </div>

            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>

            <div class="field">
              <label for="password">Password</label>
              <input id="password" name="password" type="password" autocomplete="new-password" required />
            </div>

            <div class="field">
              <label for="profilePhoto">Profile Picture</label>
              <input
                id="profilePhoto"
                name="profilePhoto"
                type="file"
                accept="image/jpeg,image/png,image/webp,.jpg,.jpeg,.png,.webp"
                required
              />
              <p class="muted">Required for your academic profile, student records, and transcript.</p>
            </div>

            <button class="primary" type="submit">Create Account</button>
          </form>

          <p class="muted">Already registered? <a href="/login">Sign in here</a></p>
        </div>
      </main>
    </section>
  </div>
</body>
</html>
