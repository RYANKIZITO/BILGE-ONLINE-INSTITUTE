<div class="auth-brand-panel">
  <div class="stack-lg">
    <div class="auth-brand-lockup">
      <div class="auth-mark"><%= mark %></div>
      <div class="auth-logo-card">
        <img
          class="auth-logo-image"
          src="/public/images/branding/logo-blue.jpg"
          alt="Bilge Online Institute"
          width="720"
          height="229"
        />
      </div>
    </div>

    <div class="stack-md">
      <div>
        <p class="auth-kicker"><%= kicker %></p>
        <h1><%= title %></h1>
        <p class="auth-copy auth-copy--lead"><%= description %></p>
      </div>

      <div class="auth-highlights">
        <% highlights.forEach((item) => { %>
          <article class="auth-point">
            <strong><%= item.title %></strong>
            <span><%= item.description %></span>
          </article>
        <% }) %>
      </div>

      <div class="auth-metrics" aria-label="Bilge platform highlights">
        <% metrics.forEach((item) => { %>
          <div class="auth-metric">
            <strong><%= item.value %></strong>
            <span><%= item.label %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <p class="auth-copy auth-copy--support"><%= supportText %></p>
</div>
