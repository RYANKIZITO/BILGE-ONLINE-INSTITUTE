<article class="glass-card course-card">
  <a class="course-cover-link" href="/programmes/<%= course.slug %>" aria-label="View <%= course.title %>">
    <img
      class="course-cover-image <%= course.hasCustomCoverImage ? 'course-cover-image--wide' : '' %>"
      src="<%= course.coverImageUrl %>"
      alt="<%= course.title %> programme cover"
      loading="lazy"
    />
  </a>
  <div class="course-card-topline">
    <span class="eyebrow"><%= course.categoryName %></span>
  </div>
  <h3><a href="/programmes/<%= course.slug %>"><%= course.title %></a></h3>
  <p><%= course.shortDescription %></p>
  <div class="course-meta">
    <div class="course-instructor">
      <% if (course.instructorPhotoUrl) { %>
        <img
          src="<%= course.instructorPhotoUrl %>"
          alt="<%= course.instructorName %>"
          class="course-avatar-image"
        />
      <% } else { %>
        <span class="course-avatar-fallback"><%= (course.instructorName || "B").charAt(0).toUpperCase() %></span>
      <% } %>
      <div>
        <strong><%= course.instructorName %></strong>
        <span><%= course.level %> • <%= course.estimatedDuration %></span>
      </div>
    </div>
    <div class="course-price-block">
      <strong class="course-price">
        Uganda: <%= course.priceUgandanUsd > 0 ? `${Math.round(course.priceUgandanUsd)} ${course.currency}` : "Contact" %>
      </strong>
      <span class="course-price-note">
        International: <%= course.priceForeignUsd > 0 ? `${Math.round(course.priceForeignUsd)} ${course.currency}` : "Contact" %>
      </span>
    </div>
  </div>
  <div class="course-footer">
    <a href="/programmes/<%= course.slug %>">View programme</a>
  </div>
</article>
