<!DOCTYPE html>
<html lang="en">
  <%- include("partials/head") %>
  <body>
    <div class="site-shell">
      <%- include("partials/header") %>

      <main>
        <section class="page-hero">
          <div class="container page-hero-panel">
            <%- include("components/breadcrumbs", { items: [{ label: "Programmes" }] }) %>
            <span class="eyebrow">Programme discovery</span>
            <h1>Course Catalog</h1>
            <p>
              Browse programmes by category, search term, and course grouping across the Bilge catalogue.
            </p>
          </div>
        </section>

        <section class="section">
          <div class="container form-card">
            <form class="site-form" method="get" action="/programmes">
              <div class="form-row">
                <label class="form-field">
                  <span class="field-label">Search programmes</span>
                  <input type="text" name="search" value="<%= filters.search %>" placeholder="Search by title or keyword" />
                </label>
                <label class="form-field">
                  <span class="field-label">Category</span>
                  <select name="category">
                    <option value="">All categories</option>
                    <% categories.forEach((category) => { %>
                      <option value="<%= category.name %>" <%= filters.category === category.name ? 'selected' : '' %>><%= category.name %></option>
                    <% }) %>
                  </select>
                </label>
              </div>
              <div class="form-row">
                <label class="form-field">
                  <span class="field-label">Sort by</span>
                  <select name="sort">
                    <option value="featured" <%= filters.sort === 'featured' ? 'selected' : '' %>>Featured</option>
                    <option value="latest" <%= filters.sort === 'latest' ? 'selected' : '' %>>Latest</option>
                    <option value="title" <%= filters.sort === 'title' ? 'selected' : '' %>>Title</option>
                    <option value="price_low" <%= filters.sort === 'price_low' ? 'selected' : '' %>>Price</option>
                  </select>
                </label>
                <div class="hero-actions">
                  <button class="button button-cta-light" type="submit">Apply filters</button>
                  <a class="button-ghost" href="/programmes">Reset</a>
                </div>
              </div>
            </form>
          </div>
        </section>

        <section class="section">
          <div class="container soft-banner pricing-banner">
            <strong>Tuition explained clearly for every visitor.</strong>
            <span>
              Bilge publishes two programme fees on the website. Students studying from Uganda pay
              the Ugandan student fee. Students outside Uganda pay the international student fee.
              Both prices are shown in USD on each programme so applicants can compare options
              openly before enrollment.
            </span>
          </div>
        </section>

        <section class="section">
          <div class="container">
            <% const groupedEntries = Object.entries(groupedCourses || {}); %>
            <% if (groupedEntries.length) { %>
              <div class="catalogue-index">
                <% groupedEntries.forEach(([categoryName, categoryCourses]) => { %>
                  <a class="catalogue-index__link" href="#category-<%= categoryName.toLowerCase().replace(/[^a-z0-9]+/g, '-') %>">
                    <%= categoryName %> (<%= categoryCourses.length %>)
                  </a>
                <% }) %>
              </div>

              <div class="catalogue-section-list">
                <% groupedEntries.forEach(([categoryName, categoryCourses]) => { %>
                  <section
                    class="catalogue-section"
                    id="category-<%= categoryName.toLowerCase().replace(/[^a-z0-9]+/g, '-') %>"
                  >
                    <div class="catalogue-section__header">
                      <div>
                        <span class="eyebrow">Category</span>
                        <h2><%= categoryName %></h2>
                      </div>
                      <span class="catalogue-section__count"><%= categoryCourses.length %> course(s)</span>
                    </div>
                    <div class="course-grid">
                      <% categoryCourses.forEach((course) => { %>
                        <%- include("components/course-card", { course }) %>
                      <% }) %>
                    </div>
                  </section>
                <% }) %>
              </div>
            <% } else { %>
              <div class="empty-state form-card">
                <h3>No programmes matched your filters.</h3>
                <p>Try a broader search or clear the category and sorting filters.</p>
              </div>
            <% } %>
          </div>
        </section>
      </main>

      <%- include("partials/footer") %>
    </div>
    <script src="/public/js/website-theme.js" defer></script>
  </body>
</html>
