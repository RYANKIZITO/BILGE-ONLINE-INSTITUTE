<div class="bilge-page-loader" data-bilge-page-loader role="status" aria-live="polite" aria-label="Loading page">
  <div class="bilge-page-loader__panel">
    <div class="bilge-page-loader__brand" aria-hidden="true">
      <img
        class="bilge-page-loader__brand--dark"
        src="/public/images/branding/logo-dark.jpg"
        alt=""
        width="720"
        height="229"
      />
      <img
        class="bilge-page-loader__brand--light"
        src="/public/images/branding/logo-light.jpg"
        alt=""
        width="684"
        height="201"
      />
    </div>
    <p class="bilge-page-loader__label">Preparing a smoother Bilge experience for you.</p>
    <div class="bilge-page-loader__track" aria-hidden="true">
      <span class="bilge-page-loader__bar"></span>
    </div>
    <div class="bilge-page-loader__note">
      <span class="bilge-page-loader__pulse"></span>
      <span>Premium loading</span>
    </div>
  </div>
</div>

<div class="utility-bar">
  <div class="container">
    <span class="utility-copy">
      <%= shell?.contactDetails?.instituteName || "Bilge Online Institute" %>:
      programmes, admissions guidance, faculty information, and contact details.
    </span>
    <div class="utility-actions">
      <nav class="utility-links" aria-label="Utility">
        <a href="/admissions">Admissions</a>
        <a href="/careers">Careers</a>
        <a href="/contact">Contact</a>
        <a href="/insights">Insights</a>
      </nav>
      <label class="site-language-control" for="website-language">
        <span>Language</span>
        <select id="website-language" data-language-select aria-label="Select website language">
          <%- include("language-options") %>
        </select>
      </label>
    </div>
  </div>
</div>

<header class="site-header" data-site-header>
  <div class="grand-opening-strip" role="region" aria-label="Grand opening announcement">
    <a class="grand-opening-strip__link" href="/admissions">
      <span class="grand-opening-strip__viewport">
        <span class="grand-opening-strip__track" aria-hidden="true">
          <span class="grand-opening-strip__message">Grand opening: May 2026. Choose your programme and reserve your place.</span>
          <span class="grand-opening-strip__message">Grand opening: May 2026. Choose your programme and reserve your place.</span>
          <span class="grand-opening-strip__message">Grand opening: May 2026. Choose your programme and reserve your place.</span>
          <span class="grand-opening-strip__message">Grand opening: May 2026. Choose your programme and reserve your place.</span>
        </span>
        <span class="sr-only">Grand opening: May 2026. Choose your programme and reserve your place.</span>
      </span>
    </a>
  </div>
  <div class="container site-nav">
    <a class="brand brand--header" href="/" aria-label="Bilge Online Institute">
      <span class="brand-logo-stack" aria-hidden="true">
        <img
          class="brand-logo brand-logo--dark"
          src="/public/images/branding/logo-dark.jpg"
          alt=""
          width="720"
          height="229"
        />
        <img
          class="brand-logo brand-logo--light"
          src="/public/images/branding/logo-light.jpg"
          alt=""
          width="684"
          height="201"
        />
      </span>
      <span class="sr-only">Bilge Online Institute</span>
    </a>

    <div class="site-nav-controls">
      <label class="site-language-control site-language-control--mobile" for="website-language-mobile">
        <span class="sr-only">Language</span>
        <select id="website-language-mobile" data-language-select aria-label="Select website language">
          <%- include("language-options") %>
        </select>
      </label>

      <button
        class="nav-toggle"
        type="button"
        data-nav-toggle
        aria-expanded="false"
        aria-controls="site-nav-panel"
        aria-label="Open navigation"
      >
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
        <span class="nav-toggle__line"></span>
        <span class="sr-only">Toggle navigation</span>
      </button>
    </div>

    <div class="site-nav-panel" id="site-nav-panel" data-nav-panel>
      <nav class="nav-links" aria-label="Primary">
        <% (shell?.navLinks || []).forEach((link) => { %>
          <a
            class="nav-link <%= currentPath === link.href || currentPath.startsWith(link.href + '/') ? 'active' : '' %>"
            href="<%= link.href %>"
          >
            <%= link.label %>
          </a>
        <% }) %>
      </nav>

      <div class="nav-actions">
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Switch theme">
          <span class="theme-toggle__label">Theme</span>
          <span class="theme-toggle__track">
            <span class="theme-toggle__thumb"></span>
          </span>
          <span class="theme-toggle__current" data-theme-current>Dark</span>
        </button>

        <a class="button-ghost" href="/login">Log In</a>
        <a class="button button-cta-light" href="/register">Sign Up for Free</a>
      </div>
    </div>
  </div>
</header>
