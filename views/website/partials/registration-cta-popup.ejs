<aside
  class="registration-cta-popup"
  data-registration-cta-popup
  role="dialog"
  aria-labelledby="registration-cta-popup-title"
  aria-describedby="registration-cta-popup-copy"
  hidden
>
  <button
    class="registration-cta-popup__close"
    type="button"
    data-registration-cta-close
    aria-label="Close registration reminder"
  >
    <span aria-hidden="true">&times;</span>
  </button>
  <p class="registration-cta-popup__eyebrow">Bilge Online Institute</p>
  <h2 id="registration-cta-popup-title">Don't go yet</h2>
  <p id="registration-cta-popup-copy">
    Start your application now and continue learning with Bilge.
  </p>
  <a class="registration-cta-popup__button" href="/register">Register now</a>
</aside>
